{
  "name": "arkaive",
  "version": "1.0.0",
  "description": "A CLI tool to tag all the files you want in a archive to escape nesting hell, while making it easy to do so.",
  "type": "module",
  "bin": {
    "arkaive": "bin/arkaive.js"
  },
  "scripts": {
    "start": "node ./bin/arkaive.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "env-paths": "^4.0.0"
  },
  "author": "Arkaive19",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
